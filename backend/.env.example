# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── Supabase JS client ────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google OAuth (future) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Seed defaults ─────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@smartpos.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=System Admin

# ── Fingerprint scanner (local ZKTeco service on enrollment PC) ───────────────
FINGERPRINT_SCANNER_URL=http://127.0.0.1:17890
