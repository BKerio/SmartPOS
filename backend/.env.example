# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# For a long-running Node backend, prefer SESSION pooler (port 5432) over transaction pooler (6543).
# Supabase Dashboard → Project Settings → Database → Connection string → "Session pooler"
DATABASE_URL="postgresql://USER:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?pgbouncer=true&connect_timeout=15"
# Direct connection — used by Prisma migrate/db push only
DIRECT_URL="postgresql://USER:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── Supabase JS client ────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Must be the full service_role JWT from Supabase Dashboard → Settings → API (starts with eyJ, ~200+ chars)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google OAuth (future) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Seed defaults ─────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@smartpos.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=System Admin

# ── Fingerprint scanner (local ZKTeco service on enrollment PC) ───────────────
FINGERPRINT_SCANNER_URL=http://127.0.0.1:17890

# ── SMTP (password reset emails) ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
# Gmail: use your Gmail address as FROM, or a verified alias
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME=Better Fork(POS)
